# Adlign environment (02_handoff §2 conventions).
# Copy to code/.env and fill real values. NEVER commit .env.
# Minimum to pass the M0 gate: DATABASE_URL, LANGSMITH_API_KEY,
# GOOGLE_API_KEY, GROQ_API_KEY.

# --- database (docker-compose default; change only if you changed compose) ---
# The role/database keep the pre-rename name `shiboleth` ON PURPOSE: Postgres
# applies POSTGRES_USER/POSTGRES_DB only when it initializes an empty volume,
# so renaming them here would not rename anything on the live production
# volume — it would only break the connection string (rebrand 2026-07-23).
DATABASE_URL=postgresql+asyncpg://shiboleth:shiboleth@localhost:5432/shiboleth

# --- LLM providers (free tier first; OpenAI/Anthropic optional) ---
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LangSmith (tracing from first commit, non-negotiable) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=adlign-production

# --- per-stage model overrides (defaults in config.py; leave blank to accept) ---
DEFAULT_MODEL_EXTRACT=
DEFAULT_MODEL_CHECK=
DEFAULT_MODEL_CLUSTER_LABEL=
DEFAULT_MODEL_REPORT=

# --- public-demo hardening (deployment plan 2026-07-13; defaults = dev off) ---
# Server-side ceiling on live-run page cap (prod demo: 8)
PAGE_CAP_MAX=
# POST /checks per-IP hourly limit; 0 or blank disables (prod demo: 3)
CHECKS_RATE_LIMIT_PER_HOUR=
# Comma-separated run ids DELETE /runs must refuse (the seeded showcase runs)
PROTECTED_RUN_IDS=
