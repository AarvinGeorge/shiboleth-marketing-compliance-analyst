# meta: single-domain reverse proxy for the Adlign demo (deploy plan
# 2026-07-13). Caddy provisions and renews HTTPS automatically for $DOMAIN
# (Let's Encrypt; sslip.io domains work too). /api/* is stripped and proxied
# to FastAPI — the web bundle is built with NEXT_PUBLIC_API_URL=/api, so the
# whole app is one origin. SSE (/api/runs/{id}/events) streams through
# reverse_proxy without extra config: Caddy auto-flushes text/event-stream.

{$DOMAIN}

encode zstd gzip

handle_path /api/* {
	reverse_proxy api:8000
}

handle {
	reverse_proxy web:3000
}
