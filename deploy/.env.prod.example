# meta: production env template for the Adlign demo VPS (deploy plan
# 2026-07-13). Copy to code/.env ON THE SERVER and fill in real values.
# NEVER commit the filled file. Keys live ONLY here, server-side — all LLM
# calls run inside the api container; the browser never sees a key.

# --- deployment ---
# Your domain (Caddy gets HTTPS for it automatically). No https:// prefix.
# No domain yet? Use <your-server-ip>.sslip.io, e.g. 203.0.113.7.sslip.io
DOMAIN=demo.example.com

# Postgres password for the dockerized DB (pick any long random string;
# it never leaves the docker network). DATABASE_URL is derived from this
# automatically in docker-compose.prod.yml — do not set it here.
POSTGRES_PASSWORD=change_me_long_random

# --- LLM providers (same keys as dev; set hard monthly spend caps in the
#     Anthropic and OpenAI consoles BEFORE going live) ---
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LangSmith tracing ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=adlign-production

# --- public-demo hardening (ON in prod) ---
# Live runs crawl at most this many pages regardless of what the UI asks for
PAGE_CAP_MAX=8
# Each visitor IP can start at most this many check runs per hour
CHECKS_RATE_LIMIT_PER_HOUR=3
# The seeded showcase runs; DELETE is refused for these ids
# (deploy/make_seed.sh prints the current list when it builds the dump)
PROTECTED_RUN_IDS=

# Browser origins allowed to call the API cross-origin (comma list).
# Needed when the frontend is hosted off-VPS (e.g. Vercel). Unset = dev
# default (http://localhost:3000 only); same-origin traffic via Caddy is
# unaffected either way.
CORS_ALLOW_ORIGINS=
